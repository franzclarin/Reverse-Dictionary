generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id             String      @id @default(cuid())
  word           String      @unique
  partOfSpeech   String
  definition     String
  pronunciation  String
  etymology      String
  examples       String[]
  synonyms       String[]
  domain         String
  obscurityScore Int         @default(50)
  createdAt      DateTime    @default(now())
  savedBy        SavedWord[]
}

model SavedWord {
  id      String   @id @default(cuid())
  userId  String
  wordId  String
  word    Word     @relation(fields: [wordId], references: [id])
  savedAt DateTime @default(now())

  @@unique([userId, wordId])
}

model User {
  id          String      @id
  credits     Int         @default(100)
  streak      Int         @default(0)
  lastLogin   DateTime    @default(now())
  createdAt   DateTime    @default(now())
  lookups     Lookup[]
  gameHistory GameRound[]
}

model Lookup {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model GameRound {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  game      String
  bet       Int
  outcome   Int
  createdAt DateTime @default(now())
}
